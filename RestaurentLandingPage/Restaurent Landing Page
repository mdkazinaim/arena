  { id:3, name:"Bean & Co. Café", category:"coffee", price:2, rating:4.9, reviews:2050, distance:0.3, open:true, time:"10-15 min", delivery:0, address:"2245 Folsom St", tags:["Oat milk","Wi-Fi"], img:"https://images.unsplash.com/photo-1453614512568-c4024d13c247?auto=format&fit=crop&w=800&q=70", featured:"☕ Local favorite" },
  { id:4, name:"Sakura Omakase", category:"sushi", price:4, rating:4.9, reviews:430, distance:1.2, open:true, time:"30-45 min", delivery:5.99, address:"888 Market St", tags:["Omakase","Reservations"], img:"https://images.unsplash.com/photo-1579871494447-9811cf80d66c?auto=format&fit=crop&w=800&q=70" },
