const RESTAURANTS = [
  { id:1, name:"Tony's Slice House", category:"pizza", price:2, rating:4.8, reviews:1240, distance:0.6, open:true, time:"20-30 min", delivery:2.99, address:"504 Valencia St", tags:["New York style","Wood-fired"], img:"https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?auto=format&fit=crop&w=800&q=70", featured:"🔥 Trending" },
