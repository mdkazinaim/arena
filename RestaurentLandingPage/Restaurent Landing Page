  { id:6, name:"Smokehouse 1908", category:"bbq", price:3, rating:4.7, reviews:880, distance:2.1, open:true, time:"30-40 min", delivery:3.99, address:"1908 Bryant St", tags:["Brisket","Craft beer"], img:"https://images.unsplash.com/photo-1529193591184-b1d58069ecdd?auto=format&fit=crop&w=800&q=70" },
  { id:7, name:"Tokyo Ramen Lab", category:"ramen", price:2, rating:4.8, reviews:1530, distance:0.7, open:true, time:"20-30 min", delivery:2.99, address:"414 Mason St", tags:["Tonkotsu","Late night"], img:"https://images.unsplash.com/photo-1623341214825-9f4f963727da?auto=format&fit=crop&w=800&q=70", featured:"🍜 Ramen Fest" },
  { id:8, name:"Burger & Bones", category:"burger", price:2, rating:4.5, reviews:1120, distance:1.0, open:false, time:"Closed · 11am", delivery:1.99, address:"1024 Polk St", tags:["Smash burger","Cocktails"], img:"https://images.unsplash.com/photo-1568901346375-23c9450c58cd?auto=format&fit=crop&w=800&q=70" },
  { id:9, name:"Crust & Crumble", category:"dessert", price:2, rating:4.9, reviews:760, distance:1.4, open:true, time:"15-25 min", delivery:2.99, address:"2300 Chestnut St", tags:["Pies","Cookies"], img:"https://images.unsplash.com/photo-1488477181946-6428a0291777?auto=format&fit=crop&w=800&q=70" },
  { id:10, name:"Ocean's Edge", category:"seafood", price:4, rating:4.8, reviews:520, distance:2.8, open:true, time:"35-50 min", delivery:6.99, address:"Pier 39", tags:["Oysters","Sea view"], img:"https://images.unsplash.com/photo-1559339352-11d035aa65de?auto=format&fit=crop&w=800&q=70" },
  { id:11, name:"Sunrise Diner", category:"brunch", price:2, rating:4.6, reviews:1890, distance:1.6, open:true, time:"25-35 min", delivery:2.49, address:"2500 Geary Blvd", tags:["Pancakes","All day"], img:"https://images.unsplash.com/photo-1525351484163-7529414344d8?auto=format&fit=crop&w=800&q=70" },
  { id:12, name:"Slice of Naples", category:"pizza", price:2, rating:4.7, reviews:820, distance:1.1, open:true, time:"20-30 min", delivery:2.49, address:"700 Columbus Ave", tags:["Neapolitan","Marinara"], img:"https://images.unsplash.com/photo-1604068549290-dea0e4a305ca?auto=format&fit=crop&w=800&q=70" },
  { id:13, name:"Verde Bowl", category:"vegan", price:2, rating:4.5, reviews:340, distance:1.3, open:true, time:"15-25 min", delivery:1.99, address:"3401 California St", tags:["Buddha bowls","Açaí"], img:"https://images.unsplash.com/photo-1512621776951-a57141f2eefd?auto=format&fit=crop&w=800&q=70" },
  { id:14, name:"Morning Pour", category:"coffee", price:1, rating:4.8, reviews:610, distance:0.5, open:true, time:"10-15 min", delivery:0, address:"170 Spear St", tags:["Espresso","Pastries"], img:"https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&w=800&q=70" },
  { id:15, name:"The Taco Truck", category:"taco", price:1, rating:4.9, reviews:2400, distance:0.8, open:true, time:"10-20 min", delivery:0, address:"24th & Mission", tags:["Street food","Carne asada"], img:"https://images.unsplash.com/photo-1551504734-5ee1c4a1479b?auto=format&fit=crop&w=800&q=70", featured:"🌮 Taco Tuesday" },
  { id:16, name:"Sashimi Story", category:"sushi", price:3, rating:4.6, reviews:280, distance:2.0, open:true, time:"30-40 min", delivery:4.99, address:"500 Post St", tags:["Sashimi","Sake"], img:"https://images.unsplash.com/photo-1611143669185-af224c5e3252?auto=format&fit=crop&w=800&q=70" }
];

/* ---------- STATE ---------- */
const state = {
  search: '',
  category: 'all',
  minRating: 0,
  maxPrice: 4,
  sort: 'popular',
  favorites: new Set(JSON.parse(localStorage.getItem('favorites') || '[]')),
  location: 'San Francisco, CA'
};

/* ---------- CATEGORY BAR ---------- */
function renderCategories() {
  const bar = document.getElementById('categoryBar');
  bar.innerHTML = CATEGORIES.map(c => `
    <button data-cat="${c.id}" class="cat-btn shrink-0 px-4 py-2.5 rounded-full border border-ink/10 bg-white text-sm font-medium flex items-center gap-2 hover:border-ink/30 transition ${c.id===state.category?'chip-active':''}">
      <span>${c.icon}</span>${c.name}
    </button>
  `).join('');
  bar.querySelectorAll('.cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      state.category = btn.dataset.cat;
      document.getElementById('searchInput').value = '';
      state.search = '';
      renderCategories();
      renderResults();
    });
  });
}

function setQuickCategory(name) {
  const cat = CATEGORIES.find(c => c.name.toLowerCase() === name.toLowerCase());
  if (!cat) return;
  state.category = cat.id;
  document.getElementById('searchInput').value = '';
  state.search = '';
  renderCategories();
  renderResults();
  document.getElementById('resultsGrid').scrollIntoView({behavior:'smooth', block:'start'});
}

/* ---------- RENDER RESULTS ---------- */
function renderResults() {
  const grid = document.getElementById('resultsGrid');
  const empty = document.getElementById('emptyState');
  document.getElementById('resultCount').textContent = `${filteredSorted().length} spots found`;

  const items = filteredSorted();
  if (!items.length) {
    grid.innerHTML = '';
    empty.classList.remove('hidden');
    return;
  }
  empty.classList.add('hidden');

  grid.innerHTML = items.map((r, i) => `
    <article class="fade-up bg-white border border-ink/10 rounded-2xl overflow-hidden card-shadow hover:-translate-y-1 transition group" style="animation-delay:${i*40}ms">
      <div class="relative h-44 overflow-hidden">
        <img src="${r.img}" alt="${r.name}" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition duration-500" onerror="this.src='https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&w=800&q=70'"/>
        ${r.featured ? `<span class="absolute top-3 left-3 px-2.5 py-1 rounded-full bg-white/90 backdrop-blur text-[11px] font-semibold">${r.featured}</span>` : ''}
        <button onclick="toggleFav(${r.id}, this)" class="heart-btn absolute top-3 right-3 w-9 h-9 rounded-full bg-white/95 backdrop-blur flex items-center justify-center hover:scale-110 transition ${state.favorites.has(r.id)?'active':''}" title="Save">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </button>
        ${!r.open ? `<div class="absolute inset-0 bg-ink/40 flex items-center justify-center"><span class="px-3 py-1 rounded-full bg-cream text-ink text-xs font-semibold">Closed</span></div>` : ''}
      </div>
      <div class="p-4">
        <div class="flex items-start justify-between gap-2">
          <div>
            <h3 class="font-bold text-[15px] leading-tight">${r.name}</h3>
            <p class="text-xs text-ink/60 mt-0.5">${r.address}</p>
          </div>
          <div class="shrink-0 flex items-center gap-1 px-2 py-1 rounded-full bg-cream border border-ink/10 text-xs font-semibold">
            <span class="star">★</span>${r.rating}
          </div>
        </div>
        <div class="mt-3 flex flex-wrap gap-1.5">
          ${r.tags.map(t => `<span class="text-[11px] px-2 py-0.5 rounded-full bg-cream border border-ink/10 text-ink/70">${t}</span>`).join('')}
        </div>
        <div class="mt-3 pt-3 border-t border-ink/10 flex items-center justify-between text-xs">
          <div class="flex items-center gap-3 text-ink/70">
            <span class="font-semibold text-ink">${'$'.repeat(r.price)}</span>
            <span>·</span>
            <span>${r.distance} km</span>
            <span>·</span>
            <span>${r.time}</span>
          </div>
          <button class="px-3 py-1.5 rounded-full bg-ink text-cream text-[11px] font-semibold hover:scale-105 transition">View</button>
        </div>
      </div>
    </article>
  `).join('');
}

function filteredSorted() {
  let list = RESTAURANTS.filter(r => {
    if (state.category !== 'all' && r.category !== state.category) return false;
    if (r.rating < state.minRating) return false;
    if (r.price > state.maxPrice) return false;
    if (state.search) {
      const q = state.search.toLowerCase();
      const hay = (r.name + ' ' + r.address + ' ' + r.tags.join(' ') + ' ' + r.category).toLowerCase();
      if (!hay.includes(q)) return false;
    }
    return true;
  });
  switch (state.sort) {
    case 'rating': list.sort((a,b) => b.rating - a.rating); break;
    case 'distance': list.sort((a,b) => a.distance - b.distance); break;
    case 'price-asc': list.sort((a,b) => a.price - b.price); break;
    case 'price-desc': list.sort((a,b) => b.price - a.price); break;
    case 'newest': list.sort((a,b) => b.id - a.id); break;
    default: list.sort((a,b) => b.reviews - a.reviews);
  }
  return list;
}

/* ---------- FAVORITES ---------- */
function toggleFav(id, btn) {
  if (state.favorites.has(id)) { state.favorites.delete(id); btn.classList.remove('active'); }
  else { state.favorites.add(id); btn.classList.add('active'); }
  localStorage.setItem('favorites', JSON.stringify([...state.favorites]));
}

/* ---------- FILTERS WIRING ---------- */
document.getElementById('searchInput').addEventListener('input', e => {
  state.search = e.target.value;
  renderResults();
});
document.getElementById('searchBtn').addEventListener('click', () => renderResults());
document.getElementById('searchInput').addEventListener('keydown', e => { if (e.key === 'Enter') renderResults(); });

document.getElementById('ratingRange').addEventListener('input', e => {
  state.minRating = parseFloat(e.target.value);
  document.getElementById('ratingLabel').textContent = state.minRating ? `${state.minRating}+` : 'Any';
  renderResults();
});

document.querySelectorAll('.price-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const p = parseInt(btn.dataset.price);
    state.maxPrice = state.maxPrice === p ? 4 : p;
    document.querySelectorAll('.price-btn').forEach(b => {
      b.classList.toggle('bg-ink', parseInt(b.dataset.price) <= state.maxPrice && state.maxPrice !== 4);
      b.classList.toggle('text-cream', parseInt(b.dataset.price) <= state.maxPrice && state.maxPrice !== 4);
    });
    renderResults();
  });
});

document.getElementById('sortSelect').addEventListener('change', e => { state.sort = e.target.value; renderResults(); });
document.getElementById('clearFilters').addEventListener('click', clearAllFilters);
function clearAllFilters() {
  state.search = ''; state.category = 'all'; state.minRating = 0; state.maxPrice = 4; state.sort = 'popular';
  document.getElementById('searchInput').value = '';
  document.getElementById('ratingRange').value = 0;
  document.getElementById('ratingLabel').textContent = 'Any';
  document.getElementById('sortSelect').value = 'popular';
  document.querySelectorAll('.price-btn').forEach(b => { b.classList.remove('bg-ink','text-cream'); });
  renderCategories(); renderResults();
}

/* ---------- LOCATION ---------- */
function openLocationModal() { document.getElementById('locationModal').classList.remove('hidden'); document.getElementById('locationInput').focus(); }
function closeLocationModal() { document.getElementById('locationModal').classList.add('hidden'); }
function setLocation() {
  const v = document.getElementById('locationInput').value.trim();
  if (v) { state.location = v; document.getElementById('locationLabel').textContent = v; }
  closeLocationModal();
}
function quickLocation(v) { state.location = v; document.getElementById('locationLabel').textContent = v; closeLocationModal(); }
document.getElementById('locateBtn').addEventListener('click', () => {
  state.location = 'Current location'; document.getElementById('locationLabel').textContent = '📍 Current location';
});

/* ---------- NEWSLETTER ---------- */
function subscribe(form) {
  document.getElementById('toast').classList.remove('hidden');
  setTimeout(() => document.getElementById('toast').classList.add('hidden'), 2400);
  form.reset();
}

/* ---------- MOBILE MENU ---------- */
document.getElementById('mobileMenuBtn').addEventListener('click', () => {
  alert('Mobile menu: Lists · Reservations · Sign in · List your spot');
});

/* ---------- INIT ---------- */
renderCategories();
renderResults();
</script>
